{
  "name": "PC Parts Shop - Tro ly khach hang",
  "nodes": [
    {
      "name": "Webhook",
      "type": "n8n-nodes-base.webhook",
      "parameters": {
        "httpMethod": "POST",
        "path": "pc-shop-chat",
        "responseMode": "responseNode"
      }
    },
    {
      "name": "Lay du lieu website",
      "type": "n8n-nodes-base.httpRequest",
      "parameters": {
        "method": "GET",
        "url": "={{ $json.contextApiUrl }}",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "q",
              "value": "={{ $json.message }}"
            },
            {
              "name": "limit",
              "value": "12"
            }
          ]
        },
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "X-AI-Context-Token",
              "value": "={{ $json.contextApiToken }}"
            }
          ]
        },
        "options": {}
      }
    },
    {
      "name": "AI Agent",
      "type": "@n8n/n8n-nodes-langchain.agent",
      "parameters": {
        "text": "=Cau hoi khach: {{ $('Webhook').item.json.message }}\n\nDu lieu website dang co:\n{{ JSON.stringify($json) }}",
        "options": {
          "systemMessage": "Ban la tro ly ban hang cua PC Parts Shop (linh kien may tinh Viet Nam). Chi dung du lieu website duoc cung cap de tu van san pham, gia, ton kho, danh muc, cach dat hang, Build PC va hoan tra. Neu khong co du lieu phu hop, hay noi khach xem website hoac lien he hotline. Tra loi ngan gon, tieng Viet. Khong bia gia cu the neu khong co trong du lieu."
        }
      }
    },
    {
      "name": "Respond to Webhook",
      "type": "n8n-nodes-base.respondToWebhook",
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ { \"reply\": $json.output } }}"
      }
    }
  ],
  "connections": {
    "Webhook": { "main": [[{ "node": "Lay du lieu website", "type": "main", "index": 0 }]] },
    "Lay du lieu website": { "main": [[{ "node": "AI Agent", "type": "main", "index": 0 }]] },
    "AI Agent": { "main": [[{ "node": "Respond to Webhook", "type": "main", "index": 0 }]] }
  }
}
